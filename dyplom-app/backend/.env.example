# Copy to .env and fill in values:
#   copy .env.example .env   (Windows, from backend folder)
#   cp .env.example .env     (macOS/Linux)

# --- Required ---
# Local MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/dyplom-app
# MongoDB Atlas (SRV):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/dyplom-app?retryWrites=true&w=majority
#
# If Node reports querySrv ENOTFOUND but nslookup SRV works (common on Windows), use the
# "standard connection string" from Atlas (mongodb://, three hosts, no +srv) — copy it from:
# Atlas → Database → Connect → Drivers → full string options, or Compass.
# Example shape (replace USER, PASSWORD URL-encoded, DB name, and replicaSet from Atlas):
# MONGODB_URI=mongodb://USER:PASSWORD@host-shard-00-00.xxx.mongodb.net:27017,host-shard-00-01.xxx.mongodb.net:27017,host-shard-00-02.xxx.mongodb.net:27017/dyplom-app?tls=true&authSource=admin&replicaSet=atlas-xxxxx-shard-0&retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/dyplom-app?retryWrites=true&w=majority

# Secret for JWT (use a long random string in production, min ~32 chars)
JWT_SECRET=change-me-to-a-long-random-secret

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Optional: one-time migration User.favorites -> likes collection ---
# RUN_FAV_MIGRATION=true

# --- Optional: AWS S3 (image uploads via /api/upload) ---
# AWS_REGION=eu-north-1
# AWS_S3_BUCKET_NAME=your-bucket-name
# AWS_S3_BUCKET_URL=https://your-bucket-name.s3.eu-north-1.amazonaws.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Optional: SendGrid (email reminders in pushReminders) ---
# SENDGRID_API_KEY=
# SENDGRID_FROM=noreply@yourdomain.com

# --- CORS (web app) ---
# Comma-separated origins. In development, http://localhost:5173 and http://127.0.0.1:5173 are always allowed;
# add more here (e.g. alternate dev ports or staging).
# In production (NODE_ENV=production), ONLY these origins are allowed — set your real site:
# CORS_ORIGIN=https://dyplom.example.com,https://www.dyplom.example.com
# CORS_ORIGIN=http://localhost:4173
